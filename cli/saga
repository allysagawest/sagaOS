#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# Saga Minimal Installer (Fedora-first)
# - Installs baseline Hyprland stack in controlled stages.
# - Copies Saga's baseline Hypr config directly into ~/.config/hypr/hyprland.conf.
# - Keeps uninstall targeted to Saga-related files/packages.
###############################################################################

# Resolve repository root robustly:
# - handles direct execution: ./cli/saga
# - handles symlinked execution: ~/.local/bin/saga -> <repo>/cli/saga
SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  SCRIPT_PATH="$(readlink -f "$SCRIPT_PATH" 2>/dev/null || echo "$SCRIPT_PATH")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_ROOT="${SAGA_REPO_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
# Fallback for ad-hoc runs where current directory is the repo root.
if [[ ! -f "$REPO_ROOT/desktop/hypr/hyprland.conf" && -f "$PWD/desktop/hypr/hyprland.conf" ]]; then
  REPO_ROOT="$PWD"
fi
SAGA_SHARE_DIR="$HOME/.local/share/saga"
SAGA_CACHE_DIR="$HOME/.cache/saga"
HYPR_CONFIG_DIR="$HOME/.config/hypr"
HYPR_CONFIG_FILE="$HYPR_CONFIG_DIR/hyprland.conf"
SAGA_HYPR_CONFIG_SOURCE="$REPO_ROOT/desktop/hypr/hyprland.conf"
SWAYNC_CONFIG_DIR="$HOME/.config/swaync"
SWAYNC_CONFIG_FILE="$SWAYNC_CONFIG_DIR/config.json"
SAGA_SWAYNC_CONFIG_SOURCE="$REPO_ROOT/desktop/swaync/config.json"

DISTRO=""
PKG_MANAGER=""

# Package/runtime checks are represented as: package_name|command_name.
REQUIRED_COMPONENTS=(
  "hyprland|Hyprland"
  # Future baseline additions (disabled for now):
  # "pipewire|pipewire"
  # "wireplumber|wireplumber"
  # "xdg-desktop-portal-hyprland|xdg-desktop-portal-hyprland"
  # "wl-clipboard|wl-copy"
  # "grim|grim"
  # "slurp|slurp"
  "kitty|kitty"
  "swww|swww"
  "waybar|waybar"
  "SwayNotificationCenter|swaync"
  "libnotify|notify-send"
)

# Full package cleanup set for uninstall (Fedora stage).
# Keep this broader than the active install set so uninstall can clean older Saga attempts too.
UNINSTALL_PACKAGES=(
  hyprland
  pipewire
  wireplumber
  xdg-desktop-portal-hyprland
  wl-clipboard
  grim
  slurp
  kitty
  waybar
  walker
  eww
  SwayNotificationCenter
  swww
  hyprlock
  hypridle
)

usage() {
  cat <<USAGE
Usage:
  ./cli/saga install
  ./cli/saga uninstall
  ./cli/saga doctor
USAGE
}

###############################################################################
# Platform detection
###############################################################################

# Detect supported distro from /etc/os-release.
detect_distro() {
  if [[ ! -r /etc/os-release ]]; then
    echo "[ERROR] Cannot detect distro: /etc/os-release not found" >&2
    exit 1
  fi

  # shellcheck disable=SC1091
  source /etc/os-release
  DISTRO="${ID:-unknown}"

  case "$DISTRO" in
    fedora)
      ;;
    *)
      echo "[ERROR] Unsupported distro: $DISTRO" >&2
      echo "[INFO] Currently supported: fedora" >&2
      exit 1
      ;;
  esac
}

# Resolve package manager for current distro.
detect_package_manager() {
  case "$DISTRO" in
    fedora)
      PKG_MANAGER="dnf"
      ;;
    *)
      echo "[ERROR] No package manager mapping for distro: $DISTRO" >&2
      exit 1
      ;;
  esac

  if ! command -v "$PKG_MANAGER" >/dev/null 2>&1; then
    echo "[ERROR] Package manager '$PKG_MANAGER' not found" >&2
    exit 1
  fi
}

###############################################################################
# Package install helpers
###############################################################################

# Return success if package is already installed.
is_package_installed() {
  local pkg="$1"
  case "$PKG_MANAGER" in
    dnf)
      rpm -q "$pkg" >/dev/null 2>&1
      ;;
    *)
      return 1
      ;;
  esac
}

# Install a package safely:
# - skip if package metadata is unavailable
# - warn on unknown package manager
install_pkg() {
  local pkg="$1"

  case "$PKG_MANAGER" in
    dnf)
      if dnf info "$pkg" >/dev/null 2>&1; then
        echo "[INSTALLING] $pkg"
        sudo dnf install -y "$pkg"
      else
        echo "[SKIP] $pkg not available"
      fi
      ;;
    *)
      echo "[WARN] Unknown package manager"
      ;;
  esac
}

# Idempotent install of one package.
install_single_package() {
  local pkg="$1"

  if is_package_installed "$pkg"; then
    echo "[OK] $pkg"
    return 0
  fi

  install_pkg "$pkg"
  if is_package_installed "$pkg"; then
    echo "[OK] $pkg"
  else
    echo "[SKIP] $pkg not installed"
  fi
}

# Install all active required packages.
install_packages() {
  local item pkg
  for item in "${REQUIRED_COMPONENTS[@]}"; do
    pkg="${item%%|*}"
    install_single_package "$pkg"
  done
}

###############################################################################
# Config install
###############################################################################

install_config() {
  # Keep config behavior simple:
  # copy tracked repo configs as-is into the user's config directory.
  mkdir -p "$HYPR_CONFIG_DIR" "$SWAYNC_CONFIG_DIR" "$SAGA_SHARE_DIR" "$SAGA_CACHE_DIR"
  if [[ -f "$SAGA_HYPR_CONFIG_SOURCE" ]]; then
    cp "$SAGA_HYPR_CONFIG_SOURCE" "$HYPR_CONFIG_FILE"
  else
    echo "[ERROR] Missing Saga Hyprland baseline config: $SAGA_HYPR_CONFIG_SOURCE" >&2
    exit 1
  fi

  echo "[OK] Installed config: $HYPR_CONFIG_FILE"

  if [[ -f "$SAGA_SWAYNC_CONFIG_SOURCE" ]]; then
    cp "$SAGA_SWAYNC_CONFIG_SOURCE" "$SWAYNC_CONFIG_FILE"
  else
    echo "[ERROR] Missing Saga swaync config: $SAGA_SWAYNC_CONFIG_SOURCE" >&2
    exit 1
  fi

  echo "[OK] Installed config: $SWAYNC_CONFIG_FILE"
}

###############################################################################
# Future stage placeholders
###############################################################################

install_stage_bar() {
  # Placeholder for future stage: waybar install/config
  :
}

install_stage_notifications() {
  # Placeholder for future stage: swaync install/config
  :
}

install_stage_launcher() {
  # Placeholder for future stage: launcher install/config
  :
}

install_stage_widgets() {
  # Placeholder for future stage: eww/widgets install/config
  :
}

install_stage_utilities() {
  # Placeholder for future stage: extra desktop utilities
  :
}

###############################################################################
# Top-level commands
###############################################################################

install() {
  detect_distro
  detect_package_manager
  install_config
  install_packages

  # Reload active Hyprland session so updated binds/config take effect immediately.
  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi

  # Future staged installers (intentionally disabled)
  # install_stage_bar
  # install_stage_notifications
  # install_stage_launcher
  # install_stage_widgets
  # install_stage_utilities

  echo "Saga install complete"
}

doctor() {
  local item label cmd missing=0

  detect_distro

  for item in "${REQUIRED_COMPONENTS[@]}"; do
    label="${item%%|*}"
    cmd="${item##*|}"

    if command -v "$cmd" >/dev/null 2>&1; then
      echo "✓ $label installed"
    else
      echo "✗ $label missing"
      missing=1
    fi
  done

  if [[ -f "$HYPR_CONFIG_FILE" ]]; then
    echo "✓ hypr config present ($HYPR_CONFIG_FILE)"
  else
    echo "✗ hypr config missing ($HYPR_CONFIG_FILE)"
    missing=1
  fi

  if grep -Eq '^[[:space:]]*bind[[:space:]]*=.*\bT\b.*exec,[[:space:]]*(\$terminal_app|kitty)\b' "$HYPR_CONFIG_FILE" 2>/dev/null; then
    echo "✓ terminal bind present in hyprland.conf"
  else
    echo "✗ terminal bind missing in hyprland.conf"
    missing=1
  fi

  if grep -Eq '^[[:space:]]*exec-once[[:space:]]*=[[:space:]]*swaync([[:space:]]|$)' "$HYPR_CONFIG_FILE" 2>/dev/null; then
    echo "✓ swaync autostart present in hyprland.conf"
  else
    echo "✗ swaync autostart missing in hyprland.conf"
    missing=1
  fi

  if [[ -f "$SWAYNC_CONFIG_FILE" ]]; then
    echo "✓ swaync config present ($SWAYNC_CONFIG_FILE)"
  else
    echo "✗ swaync config missing ($SWAYNC_CONFIG_FILE)"
    missing=1
  fi

  if grep -Eq 'disable_hyprland_qtutils_check[[:space:]]*=[[:space:]]*true' "$HYPR_CONFIG_FILE" 2>/dev/null; then
    echo "✓ qtutils warning disabled in hyprland.conf"
  else
    echo "✗ qtutils warning setting missing in hyprland.conf"
    missing=1
  fi

  if [[ "$missing" -ne 0 ]]; then
    return 1
  fi
}

uninstall() {
  local target confirm
  local targets=(
    "$HOME/.config/hypr"
    "$HOME/.config/waybar"
    "$HOME/.config/walker"
    "$HOME/.config/eww"
    "$HOME/.config/swaync"
    "$HOME/.config/saga"
    "$HOME/.local/share/saga"
    "$HOME/.cache/saga"
    "$HOME/.local/bin/saga"
  )
  local pkg
  local to_remove=()

  detect_distro
  detect_package_manager

  for pkg in "${UNINSTALL_PACKAGES[@]}"; do
    if is_package_installed "$pkg"; then
      to_remove+=("$pkg")
    fi
  done

  echo "Saga will remove the following paths:"
  echo
  for target in "${targets[@]}"; do
    echo "$target"
  done
  echo
  if [[ "${#to_remove[@]}" -gt 0 ]]; then
    echo "Saga will also uninstall these system packages:"
    echo
    for pkg in "${to_remove[@]}"; do
      echo "$pkg"
    done
    echo
  else
    echo "No Saga-related system packages detected for removal."
    echo
  fi
  read -r -p "Continue? (y/n) " confirm

  case "$confirm" in
    y|Y)
      if [[ "${#to_remove[@]}" -gt 0 ]]; then
        echo "Removing Saga system packages..."
        case "$PKG_MANAGER" in
          dnf)
            if sudo dnf remove -y "${to_remove[@]}" >/dev/null; then
              for pkg in "${to_remove[@]}"; do
                echo "✓ $pkg uninstalled"
              done
            else
              echo "[ERROR] Failed to uninstall one or more packages" >&2
              exit 1
            fi
            ;;
          *)
            echo "[ERROR] Unsupported package manager for uninstall: $PKG_MANAGER" >&2
            exit 1
            ;;
        esac
      fi

      echo "Removing Saga configs..."
      for target in "${targets[@]}"; do
        if [[ -e "$target" ]]; then
          rm -rf "$target"
        fi
        echo "✓ $target removed"
      done
      echo "Saga uninstall complete"
      ;;
    *)
      echo "Uninstall cancelled"
      ;;
  esac
}

# CLI entrypoint.
main() {
  case "${1:-}" in
    install)
      install
      ;;
    uninstall)
      uninstall
      ;;
    doctor)
      doctor
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      echo "[ERROR] Unknown command: $1" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
