#!/usr/bin/env bash
set -euo pipefail

if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
  echo "[ERROR] Do not run Saga as root." >&2
  exit 1
fi

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  SCRIPT_PATH="$(readlink -f "$SCRIPT_PATH" 2>/dev/null || echo "$SCRIPT_PATH")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_ROOT="${SAGA_REPO_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

if [[ ! -f "$REPO_ROOT/desktop/hypr/hyprland.conf" && -f "$PWD/desktop/hypr/hyprland.conf" ]]; then
  REPO_ROOT="$PWD"
fi

# shellcheck disable=SC1091
source "$REPO_ROOT/scripts/lib/saga-installer.sh"
saga_init "$REPO_ROOT"

SAGA_APPLY_THEME_SCRIPT="$REPO_ROOT/cli/theme/apply_theme.sh"

usage() {
  cat <<'USAGE'
Usage:
  ./cli/saga install [--dry-run]
  ./cli/saga dry-run [install|uninstall]
  ./cli/saga theme <name>
  ./cli/saga uninstall [--dry-run]
  ./cli/saga doctor
USAGE
}

apply_theme() {
  local theme_name="${1:-default}"
  if [[ ! -x "$SAGA_APPLY_THEME_SCRIPT" ]]; then
    echo "[ERROR] Missing script: $SAGA_APPLY_THEME_SCRIPT" >&2
    exit 1
  fi
  "$SAGA_APPLY_THEME_SCRIPT" "$REPO_ROOT" "$theme_name"
}

install() {
  saga_install_flow
  if [[ "$SAGA_DRY_RUN" -eq 1 ]]; then
    echo "[DRY-RUN] Would apply theme: default"
  else
    apply_theme "default"
  fi

  if command -v hyprctl >/dev/null 2>&1 && [[ "$SAGA_DRY_RUN" -eq 0 ]]; then
    hyprctl reload >/dev/null 2>&1 || true
  fi

  echo "Saga install complete"
}

uninstall() {
  saga_uninstall_flow
  echo "Saga uninstall complete"
}

doctor() {
  saga_doctor
}

main() {
  local command="${1:-}"

  case "$command" in
    install)
      shift || true
      if [[ "${1:-}" == "--dry-run" ]]; then
        SAGA_DRY_RUN=1
      fi
      install
      ;;
    dry-run)
      shift || true
      SAGA_DRY_RUN=1
      case "${1:-install}" in
        install)
          install
          ;;
        uninstall)
          uninstall
          ;;
        *)
          echo "[ERROR] Unknown dry-run target: ${1:-}" >&2
          usage
          exit 1
          ;;
      esac
      ;;
    theme)
      apply_theme "${2:-default}"
      ;;
    uninstall)
      shift || true
      if [[ "${1:-}" == "--dry-run" ]]; then
        SAGA_DRY_RUN=1
      fi
      uninstall
      ;;
    doctor)
      doctor
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      echo "[ERROR] Unknown command: $command" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
